---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import IssueRow from "../components/IssueRow.astro";
import AuthorCard from "../components/AuthorCard.astro";
import Testimonials from "../components/Testimonials.astro";
import Faq from "../components/Faq.astro";
import SignupCta from "../components/SignupCta.astro";
import { getPosts } from "../lib/beehiiv";

const posts = await getPosts({ limit: 4 });
const total = posts.length;
---

<Layout>
  <Hero />

  {/* Letzte Ausgaben — editoriale Liste */}
  <section class="mx-auto max-w-5xl px-6 pb-20">
    <div
      class="mb-2 flex items-baseline justify-between border-t border-base-content/15 pt-8"
    >
      <h2 class="eyebrow">Letzte Ausgaben</h2>
      <a
        href="/archiv"
        class="text-xs font-semibold uppercase tracking-[0.14em] text-primary hover:underline"
      >
        Alle ansehen →
      </a>
    </div>

    {
      posts.length > 0 ? (
        <ul>
          {posts.map((post, i) => (
            <li>
              <IssueRow
                post={post}
                nr={String(total - i).padStart(3, "0")}
              />
            </li>
          ))}
        </ul>
      ) : (
        <p class="py-6 text-base-content/60">
          Noch keine Ausgaben veröffentlicht. Bald geht es los!
        </p>
      )
    }
  </section>

  <AuthorCard />

  <Testimonials />

  <Faq />

  <SignupCta />
</Layout>
