---
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "../../styles/global.css";

const issues = [
  { n: "014", title: "Warum 21 Millionen?" },
  { n: "013", title: "Was ist ein Satoshi?" },
];
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Demo · Calm — Bits&Satoshis</title>
  </head>
  <body class="flex min-h-screen flex-col bg-base-100 font-sans text-base-content antialiased">
    <!-- sehr zurückhaltende Kopfzeile -->
    <header class="mx-auto flex w-full max-w-3xl items-center justify-between px-6 py-8">
      <a href="/demo/calm" class="flex items-center gap-2.5">
        <img src="/logo.svg" alt="Bits&Satoshis" class="h-9 w-auto opacity-90" />
      </a>
      <a
        href="#signup"
        class="text-sm font-medium text-base-content/60 underline-offset-4 transition-colors hover:text-primary hover:underline"
      >
        Abonnieren
      </a>
    </header>

    <!-- Hero: maximale Ruhe, viel Luft -->
    <main class="flex flex-1 items-center">
      <section class="mx-auto w-full max-w-3xl px-6 py-24 sm:py-32">
        <p class="mb-10 text-sm font-medium tracking-wide text-base-content/40">
          Der ruhige Bitcoin-Newsletter
        </p>

        <h1 class="text-5xl font-light leading-[1.1] tracking-tight sm:text-7xl">
          verstehen.<br />
          <span class="text-base-content/40">nicht spekulieren<span class="text-primary">.</span></span>
        </h1>

        <p class="mt-10 max-w-md text-lg font-light leading-relaxed text-base-content/60">
          Einmal pro Woche ein klarer Gedanke zu Bitcoin. Nichts mehr, nichts weniger.
        </p>

        <!-- Signup: eine Linie, ein Pfeil -->
        <form id="signup" class="mt-12 max-w-md" onsubmit="return false">
          <div class="flex items-center gap-4 border-b border-base-content/20 pb-3 transition-colors focus-within:border-primary">
            <input
              type="email"
              placeholder="deine@email.de"
              class="w-full bg-transparent text-lg font-light outline-none placeholder:text-base-content/30"
            />
            <button
              aria-label="Abonnieren"
              class="shrink-0 text-2xl text-base-content/40 transition-colors hover:text-primary"
            >
              →
            </button>
          </div>
          <p class="mt-3 text-xs font-light text-base-content/40">
            Kostenlos · jederzeit kündbar
          </p>
        </form>

        <!-- Letzte Ausgaben: extrem reduziert -->
        <div class="mt-24 space-y-3">
          {
            issues.map((issue) => (
              <a
                href="#"
                class="group flex items-baseline gap-4 text-base-content/55 transition-colors hover:text-base-content"
              >
                <span class="font-light tabular-nums text-base-content/30">{issue.n}</span>
                <span class="font-light">{issue.title}</span>
                <span class="ml-auto text-base-content/20 transition-all group-hover:translate-x-1 group-hover:text-primary">→</span>
              </a>
            ))
          }
        </div>
      </section>
    </main>

    <footer class="mx-auto w-full max-w-3xl px-6 py-10 text-xs font-light text-base-content/40">
      © 2026 Bits&Satoshis
    </footer>

    <!-- Demo-Umschalter -->
    <div
      class="fixed bottom-4 left-1/2 z-50 flex -translate-x-1/2 items-center gap-1 rounded-full border border-base-300 bg-base-100/90 px-2 py-1.5 text-xs shadow-lg backdrop-blur"
    >
      <span class="px-2 py-1 text-base-content/50">Demo:</span>
      <a href="/demo/editorial" class="rounded-full px-3 py-1 font-semibold text-base-content/60 hover:bg-base-200">Redaktionell</a>
      <a href="/demo/calm" class="rounded-full bg-primary px-3 py-1 font-semibold text-primary-content">Calm</a>
    </div>
  </body>
</html>
