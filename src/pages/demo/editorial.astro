---
import "../../styles/global.css";

const issues = [
  {
    n: "014",
    title: "Warum 21 Millionen?",
    date: "28. Mai 2026",
    teaser: "Über die feste Obergrenze und das Versprechen der Knappheit.",
  },
  {
    n: "013",
    title: "Was ist eigentlich ein Satoshi?",
    date: "21. Mai 2026",
    teaser: "Die kleinste Einheit von Bitcoin — und warum sie zählt.",
  },
  {
    n: "012",
    title: "Verstehen statt spekulieren",
    date: "14. Mai 2026",
    teaser: "Warum dieser Newsletter existiert.",
  },
];
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Demo · Redaktionell — Bits&Satoshis</title>
  </head>
  <body class="bg-base-100 font-sans text-base-content antialiased">
    <!-- feine Orange-Linie ganz oben (Editorial-Motiv) -->
    <div class="h-1 w-full bg-primary"></div>

    <!-- Masthead -->
    <header
      class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-6 py-5"
    >
      <a href="/demo/editorial" class="flex items-center gap-3">
        <img src="/logo.svg" alt="Bits&Satoshis" class="h-12 w-auto" />
        <span class="hidden text-sm font-semibold uppercase tracking-[0.2em] text-base-content/70 sm:block">
          Bits&Satoshis
        </span>
      </a>
      <nav class="flex items-center gap-7 text-[0.8rem] font-semibold uppercase tracking-[0.14em]">
        <a href="#" class="text-base-content/50 transition-colors hover:text-base-content">Archiv</a>
        <a href="#" class="text-base-content/50 transition-colors hover:text-base-content">Über</a>
        <a href="#signup" class="text-primary hover:underline">Abonnieren</a>
      </nav>
    </header>

    <div class="mx-auto max-w-5xl px-6">
      <div class="border-t border-base-content/15"></div>
    </div>

    <!-- Hero -->
    <section class="mx-auto max-w-5xl px-6 pb-16 pt-14">
      <p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-base-content/50">
        Ausgabe Nº 014 · 28. Mai 2026
      </p>

      <h1
        class="font-display text-[clamp(2.75rem,7vw,5.5rem)] font-semibold leading-[0.98] tracking-[-0.02em]"
      >
        Verstehen statt<br />
        <span class="font-display-italic text-primary">spekulieren.</span>
      </h1>

      <div class="mt-10 grid gap-10 md:grid-cols-[1.4fr_1fr] md:items-end">
        <p class="max-w-xl text-lg leading-relaxed text-base-content/70">
          Der ruhige Bitcoin-Newsletter für Menschen, die verstehen wollen.
          Einmal pro Woche ein klarer Gedanke — ohne Kursgeschrei, ohne Hype.
        </p>

        <form id="signup" class="w-full" onsubmit="return false">
          <label class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-base-content/50">
            Kostenlos abonnieren
          </label>
          <div class="flex items-center gap-3 border-b-2 border-base-content/25 pb-2 transition-colors focus-within:border-primary">
            <input
              type="email"
              placeholder="deine@email.de"
              class="w-full bg-transparent text-base outline-none placeholder:text-base-content/35"
            />
            <button class="shrink-0 text-sm font-bold uppercase tracking-wide text-primary">
              Abonnieren →
            </button>
          </div>
          <p class="mt-2 text-xs text-base-content/45">
            Schon 4.200 Leser · jederzeit kündbar
          </p>
        </form>
      </div>
    </section>

    <!-- Letzte Ausgaben — editoriale Liste, keine Karten -->
    <section class="mx-auto max-w-5xl px-6 pb-24">
      <div class="mb-2 flex items-baseline justify-between border-t border-base-content/15 pt-8">
        <h2 class="text-xs font-semibold uppercase tracking-[0.22em] text-base-content/50">
          Letzte Ausgaben
        </h2>
        <a href="#" class="text-xs font-semibold uppercase tracking-[0.14em] text-primary hover:underline">
          Alle ansehen →
        </a>
      </div>

      <ul>
        {
          issues.map((issue) => (
            <li>
              <a
                href="#"
                class="group grid grid-cols-[auto_1fr_auto] items-center gap-5 border-b border-base-content/12 py-6 transition-colors hover:bg-base-200/60"
              >
                <span class="font-display text-2xl font-semibold text-primary/80">
                  Nº {issue.n}
                </span>
                <span class="min-w-0">
                  <span class="font-display block text-2xl font-medium leading-snug sm:text-3xl">
                    {issue.title}
                  </span>
                  <span class="mt-1 block text-sm text-base-content/55">
                    {issue.date} — {issue.teaser}
                  </span>
                </span>
                <span class="text-xl text-base-content/30 transition-all group-hover:translate-x-1 group-hover:text-primary">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <footer class="border-t border-base-content/15">
      <div class="mx-auto max-w-5xl px-6 py-8 text-sm text-base-content/50">
        © 2026 Bits&Satoshis · Der ruhige Bitcoin-Newsletter
      </div>
    </footer>

    <!-- Demo-Umschalter -->
    <div
      class="fixed bottom-4 left-1/2 z-50 flex -translate-x-1/2 items-center gap-1 rounded-full border border-base-300 bg-base-100/90 px-2 py-1.5 text-xs shadow-lg backdrop-blur"
    >
      <span class="px-2 py-1 text-base-content/50">Demo:</span>
      <a href="/demo/editorial" class="rounded-full bg-primary px-3 py-1 font-semibold text-primary-content">Redaktionell</a>
      <a href="/demo/calm" class="rounded-full px-3 py-1 font-semibold text-base-content/60 hover:bg-base-200">Calm</a>
    </div>

    <style>
      .font-display {
        font-family: "Fraunces Variable", Georgia, serif;
        font-optical-sizing: auto;
      }
      .font-display-italic {
        font-family: "Fraunces Variable", Georgia, serif;
        font-style: italic;
        font-optical-sizing: auto;
      }
    </style>
  </body>
</html>
