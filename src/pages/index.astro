---
// SSR: Hero liest UTM/?anmeldung aus der URL, Ausgabenliste kommt live von beehiiv.
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import IssueList from "../components/IssueList.astro";
import AuthorCard from "../components/AuthorCard.astro";
import BeforeSignup from "../components/BeforeSignup.astro";
import SignupCta from "../components/SignupCta.astro";
import { getPosts } from "../lib/beehiiv";

const posts = await getPosts({ limit: 3 });
---

<Layout>
  <Hero />

  {/* Die letzten drei Ausgaben (§6.3) — überprüfbarer Beweis statt Behauptung.
      Gleicher Container wie Hero, Navbar und Footer: eine linke Kante.
      Kein Top-Padding: der Hero bringt bereits pb-16 (64px) mit. */}
  <section class="mx-auto max-w-[1080px] px-5 pb-16 sm:px-8">
    <IssueList posts={posts} eyebrow="Die letzten drei Ausgaben" />

    {/* Weg ins Archiv, gleiche Link-Affordanz wie überall:
        Dust-Unterstrich, Hover Ink (§2). 24px Abstand zur Liste (§4). */}
    <a
      href="/archiv"
      class="mt-6 inline-block text-[15px] font-medium text-ink underline decoration-dust underline-offset-[3px] hover:decoration-ink"
    >
      Alle Ausgaben
    </a>
  </section>

  <AuthorCard />

  <BeforeSignup />

  <SignupCta />
</Layout>
