---
// SSR: Hero liest UTM/?anmeldung aus der URL, Ausgabenliste kommt live von beehiiv.
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import IssueList from "../components/IssueList.astro";
import AuthorCard from "../components/AuthorCard.astro";
import PullQuote from "../components/PullQuote.astro";
import BeforeSignup from "../components/BeforeSignup.astro";
import SignupCta from "../components/SignupCta.astro";
import { getPosts } from "../lib/beehiiv";

// withContent lädt den RSS-Inhalt mit — daraus kommt die Lesezeit der Liste.
const posts = await getPosts({ limit: 3, withContent: true });

// Kuratierte Einstiegsausgabe — dieselbe Quelle wie die PullQuote unten.
// Bei Bedarf auf eine neuere repräsentative Ausgabe umziehen.
const FEATURED_ISSUE = {
  slug: "gold-vs-bitcoin-2026",
  title: "Gold vs. Bitcoin",
};

// Bisherige Themenfelder — aus echten Ausgaben, bei neuen Feldern ergänzen.
const TOPIC_AREAS = [
  "Geldpolitik",
  "Steuern",
  "ETFs",
  "Mining",
  "Quantencomputer",
  "Psychologie",
];
// 5 min CDN-Cache (Vercel cached pro URL inkl. Query — UTM-Varianten sind
// deterministisch und damit sicher). SWR: Besucher bekommen sofort die
// gecachte Seite, das CDN holt im Hintergrund eine frische.
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=300, stale-while-revalidate=86400",
);
---

<Layout>
  <Hero />

  {/* Die letzten drei Ausgaben (§6.3) — überprüfbarer Beweis statt Behauptung.
      Gleicher Container wie Hero, Navbar und Footer: eine linke Kante.
      Kein Top-Padding: der Hero bringt bereits pb-16 (64px) mit. */}
  <section class="mx-auto max-w-[1080px] px-5 pb-16 sm:px-8">
    <IssueList posts={posts} eyebrow="Die letzten drei Ausgaben" />

    {/* Themenbreite gehört zur Liste (16px): beantwortet die stille Frage
        „geht dem der Stoff aus?" — Meta-Register, keine Prosa. */}
    <p class="meta mt-4">Bisher: {TOPIC_AREAS.join(" · ")}</p>

    {/* Navigationsgruppe (24px zur Liste, 8px intern): Einstieg für Skeptiker
        und Weg ins Archiv — beide führen von der Liste weiter. */}
    <p class="mt-6 text-[15px] leading-[1.65] text-ink">
      Neu hier? Lies zuerst{" "}
      <a
        href={`/newsletter/${FEATURED_ISSUE.slug}`}
        class="font-medium underline decoration-dust underline-offset-[3px] hover:decoration-ink"
      >
        {FEATURED_ISSUE.title}
      </a>. Dann weißt du, ob das hier etwas für dich ist.
    </p>
    <a
      href="/archiv"
      class="mt-2 inline-block text-[15px] font-medium text-ink underline decoration-dust underline-offset-[3px] hover:decoration-ink"
    >
      Alle Ausgaben
    </a>
  </section>

  <AuthorCard />

  {/* Stimmprobe (§6.4a): ein echtes Zitat aus einer Ausgabe, Quelle verlinkt.
      Überprüfbare Stimme statt Behauptung — wie die Ausgabenliste oben. */}
  <PullQuote
    quote="Bitcoin wirkt von außen chaotisch. Das Chaos arbeitet mehrheitlich in die richtige Richtung."
    slug="gold-vs-bitcoin-2026"
    issueTitle="Gold vs. Bitcoin"
  />

  <BeforeSignup />

  <SignupCta format="Ein Thema · 4 Minuten · keine Kursprognosen · kostenlos" />
</Layout>
