---
// SSR: Archiv kommt live von beehiiv — neue Ausgaben ohne Redeploy.
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import IssueRow from "../components/IssueRow.astro";
import SignupCta from "../components/SignupCta.astro";
import { getPosts } from "../lib/beehiiv";

const posts = await getPosts({ limit: 100 });

// Nachladen ohne zweiten API-Weg: alle Ausgaben stehen im Markup (SEO,
// No-JS-Fallback), ab der fünften versteckt. Der Button zeigt je vier weitere.
const INITIAL_VISIBLE = 4;
const hasMore = posts.length > INITIAL_VISIBLE;

// 5 min CDN-Cache — neue Ausgaben erscheinen zeitnah, die beehiiv-API wird
// trotzdem entlastet.
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=300, stale-while-revalidate=86400",
);
---

<Layout
  title="Archiv · Bits&Satoshis"
  description="Alle Ausgaben von Bits&Satoshis, chronologisch. Bitcoin, Geld und Politik, jeden Freitag."
>
  {/* Gleicher Container und gleiche linke Kante wie Startseite und Navbar (§4).
      Kein Count-Stamp, keine Rotation, kein Orange: das Budget gehört dem
      Signup-Button am Seitenende (§2). Kein Filter, keine Suche, keine Tags —
      die Liste selbst ist die Seite (§7). */}
  <section class="mx-auto max-w-[1080px] px-5 pt-16 pb-16 sm:px-8">
    <div class="measure">
      <h1 class="h1">Archiv</h1>
      <p class="mt-4 text-[15px] leading-[1.65] text-ink text-pretty">
        Alle Ausgaben, neueste zuerst. Jede steht für sich und lässt sich
        ohne die anderen lesen.
      </p>
    </div>

    {/* Gleiche Listendarstellung wie auf der Startseite (§6.3): Haarlinie,
        dann IssueRow-Einträge, getrennt durch Haarlinien in Dust. */}
    {/* Unsichtbare h2: die IssueRow-Titel sind h3, ohne diese Ebene wäre
        die Heading-Hierarchie h1 → h3 gebrochen (a11y). */}
    <h2 class="sr-only">Alle Ausgaben</h2>

    <hr class="rule archive__rule" />

    {
      posts.length > 0 ? (
        <ul class="issue-list" id="issue-list" role="list">
          {posts.map((post, i) => (
            <li class:list={[i >= INITIAL_VISIBLE && "is-hidden"]}>
              <IssueRow post={post} />
            </li>
          ))}
        </ul>
      ) : (
        <p class="py-10 text-[15px] leading-[1.65] text-stone">
          Noch keine Ausgaben veröffentlicht. Bald geht es los.
        </p>
      )
    }

    {
      hasMore && (
        <button
          type="button"
          id="load-more"
          class="load-more"
          aria-controls="issue-list"
        >
          Ältere Ausgaben zeigen
        </button>
      )
    }

    {/* Ohne JS: komplette Liste sichtbar, Button weg. Das Verstecken ist
        reine Progressive Enhancement, kein Gatekeeping. is:inline, weil Astro
        das Style-Tag sonst aus dem noscript in den head hebt. */}
    <noscript>
      <style is:inline>
        .is-hidden {
          display: list-item !important;
        }
        .load-more {
          display: none !important;
        }
      </style>
    </noscript>
  </section>

  {/* Am Ende das Formular (§7), Spec-Text „Nächste Ausgabe: Freitag." (§6.6) */}
  <SignupCta />
</Layout>

<script>
  const STEP = 4;
  const button = document.getElementById("load-more");

  button?.addEventListener("click", () => {
    const hiddenItems = document.querySelectorAll<HTMLLIElement>(
      "#issue-list li.is-hidden",
    );

    hiddenItems.forEach((li, i) => {
      if (i < STEP) li.classList.remove("is-hidden");
    });

    // Fokus auf die erste neu sichtbare Ausgabe, damit Tastatur und
    // Screenreader dort weitermachen, wo nachgeladen wurde.
    const firstNewLink = hiddenItems[0]?.querySelector<HTMLAnchorElement>("a");
    firstNewLink?.focus();

    if (hiddenItems.length <= STEP) button.remove();
  });
</script>

<style>
  /* Die globale .rule setzt margin: 0 und gewinnt gegen Tailwind-Utilities —
     der Sektionsabstand (40px, §4) kommt deshalb hier. */
  .archive__rule {
    margin-top: var(--sp-4);
  }

  .issue-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .issue-list li.is-hidden {
    display: none;
  }

  /* Ruhiger Text-Button in Ink, gleiche Sprache wie „Mehr über mich" im
     Autoren-Block. Kein Orange: das Budget gehört dem Signup-Button (§2). */
  .load-more {
    display: inline-block;
    margin-top: var(--sp-3);
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .load-more:hover {
    text-decoration-color: var(--c-ink);
  }
</style>
