---
import Layout from "../layouts/Layout.astro";
import SignupCta from "../components/SignupCta.astro";
import { getPosts } from "../lib/beehiiv";
import { formatDate } from "../lib/format";

const posts = await getPosts({ limit: 100 });
const count = posts.length;
---

<Layout
  title="Archiv — Bits&Satoshis"
  description="Alle Ausgaben des Bits&Satoshis Bitcoin-Newsletters — in Ruhe nachlesen."
>

  <!-- ══ Masthead ══════════════════════════════════════════════ -->
  <section class="masthead">
    <div class="masthead-inner">

      <!-- Dateline -->
      <div class="dateline">
        <span class="dateline-pip" aria-hidden="true"></span>
        <span>Bits&Satoshis · Alle Ausgaben</span>
        <span class="dateline-sep" aria-hidden="true">·</span>
        <span class="dateline-sub">Bitcoin-Only · Kein Hype · Kein Trading</span>
      </div>

      <!-- Headline + Stamp -->
      <div class="headline-row">
        <h1 class="archiv-title">
          <span class="title-arch">ARCH</span><span class="title-iv">IV</span>
        </h1>

        {count > 0 && (
          <div class="count-stamp" aria-label={`${count} Ausgaben`}>
            <span class="stamp-num">{count}</span>
            <span class="stamp-label">Ausgaben</span>
          </div>
        )}
      </div>

      <!-- Sub-rule: orange bar + descriptor -->
      <div class="masthead-foot">
        <div class="orange-rule" aria-hidden="true"></div>
        <p class="masthead-descriptor">
          Der vollständige Index — jede Ausgabe als eigenständiger Text,
          ruhig geschrieben zum ruhigen Lesen.
        </p>
      </div>

    </div>
  </section>

  <!-- ══ Issue List ════════════════════════════════════════════ -->
  <section class="list-section" aria-label="Alle Ausgaben">
    <div class="list-inner">

      {posts.length > 0 ? (
        <ul class="issue-list" role="list">
          {posts.map((post, i) => {
            const nr = String(count - i).padStart(3, "0");
            const animate = i < 14;
            return (
              <li
                class:list={["issue-item", animate && "is-animated"]}
                style={animate ? `--delay: ${i * 38}ms` : ""}
              >
                <a href={`/newsletter/${post.slug}`} class="issue-link">

                  <!-- Left: issue number -->
                  <span class="issue-nr" aria-label={`Ausgabe ${nr}`}>
                    Nº&nbsp;{nr}
                  </span>

                  <!-- Centre: title + teaser -->
                  <div class="issue-content">
                    <h2 class="issue-title">{post.title}</h2>
                    {post.subtitle && (
                      <p class="issue-subtitle">{post.subtitle}</p>
                    )}
                    {!post.subtitle && post.teaser && (
                      <p class="issue-subtitle">{post.teaser}</p>
                    )}
                  </div>

                  <!-- Right: date + arrow -->
                  <div class="issue-aside">
                    {post.publishedAt && (
                      <time
                        datetime={post.publishedAt.toISOString()}
                        class="issue-date"
                      >
                        {formatDate(post.publishedAt)}
                      </time>
                    )}
                    <span class="issue-arrow" aria-hidden="true">→</span>
                  </div>

                </a>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="list-empty">
          Noch keine Ausgaben veröffentlicht. Bald geht es los.
        </p>
      )}

    </div>
  </section>

  <!-- ══ CTA ══════════════════════════════════════════════════ -->
  <div class="cta-wrap">
    <SignupCta
      title="Keine Ausgabe verpassen"
      text="Neue Ausgaben landen direkt in deinem Postfach — einmal pro Woche, in Ruhe zu lesen."
    />
  </div>

</Layout>

<style>
  /* ── Masthead ────────────────────────────────────────────── */
  .masthead {
    background: var(--c-paper);
    padding: 0 1.5rem 0;
  }

  .masthead-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Dateline — Zeitungs-Kopfzeile */
  .dateline {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--c-rule);
    margin-bottom: 2rem;
    font-family: var(--f-body);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-stone);
  }

  .dateline-pip {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-orange);
    flex-shrink: 0;
  }

  .dateline-sep {
    color: var(--c-rule);
  }

  .dateline-sub {
    color: var(--c-dust);
  }

  @media (max-width: 520px) {
    .dateline-sep,
    .dateline-sub { display: none; }
  }

  /* Headline row — title + rotierter Stempel */
  .headline-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  /* ARCHIV in zwei Farben */
  .archiv-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(3.75rem, 14vw, 10rem);
    line-height: 0.87;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    user-select: none;
  }

  .title-arch { color: var(--c-ink); }
  .title-iv   { color: var(--c-orange); }

  /* Briefmarken-Stempel */
  .count-stamp {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 84px;
    height: 84px;
    border: 2.5px solid var(--c-orange);
    border-radius: 50%;
    margin-bottom: 1rem;
    transform: rotate(9deg);
    transition: transform 400ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .count-stamp:hover {
    transform: rotate(0deg);
  }

  .stamp-num {
    font-family: var(--f-display);
    font-size: 1.875rem;
    line-height: 1;
    color: var(--c-ink);
    letter-spacing: 0;
  }

  .stamp-label {
    font-family: var(--f-body);
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-stone);
    margin-top: 2px;
  }

  /* Orange Abschluss-Regel + Descriptor */
  .masthead-foot {
    margin-top: 1.25rem;
  }

  .orange-rule {
    height: 3px;
    background: var(--c-orange);
    margin-bottom: 1rem;
  }

  .masthead-descriptor {
    font-family: var(--f-body);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.7;
    color: var(--c-stone);
    max-width: 66ch;
    padding-bottom: 2.5rem;
  }

  /* ── Issue List ──────────────────────────────────────────── */
  .list-section {
    background: var(--c-paper);
    padding: 0 1.5rem;
  }

  .list-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .issue-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Stagger-Animation für die ersten 14 Zeilen */
  .issue-item.is-animated {
    opacity: 0;
    animation: rowReveal 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes rowReveal {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .issue-item.is-animated {
      animation: none;
      opacity: 1;
    }
  }

  /* ── Issue Row ───────────────────────────── */
  .issue-link {
    display: grid;
    grid-template-columns: 5.5rem 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0 1.5rem 1rem;
    border-bottom: 1px solid var(--c-rule);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: padding-left 220ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Oranger linker Indikator-Balken */
  .issue-link::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    bottom: 8px;
    width: 3px;
    background: var(--c-orange);
    transform: scaleY(0);
    transform-origin: center;
    border-radius: 0;
    transition: transform 240ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .issue-link:hover {
    padding-left: 1.5rem;
  }

  .issue-link:hover::before {
    transform: scaleY(1);
  }

  .issue-link:hover .issue-title {
    color: var(--c-orange);
  }

  .issue-link:hover .issue-arrow {
    transform: translateX(5px);
    color: var(--c-orange);
  }

  @media (max-width: 640px) {
    .issue-link {
      grid-template-columns: 4rem 1fr;
      grid-template-rows: auto auto;
      gap: 0.75rem 1rem;
      padding-left: 0.75rem;
    }

    .issue-aside {
      grid-column: 2;
    }

    .issue-link:hover {
      padding-left: 1.25rem;
    }
  }

  /* Nummer — Chaney Orange */
  .issue-nr {
    font-family: var(--f-display);
    font-size: clamp(0.75rem, 1.4vw, 0.9375rem);
    font-weight: 400;
    color: var(--c-orange);
    letter-spacing: 0;
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1;
  }

  /* Titel + Teaser */
  .issue-content {
    min-width: 0;
  }

  .issue-title {
    font-family: var(--f-display);
    font-size: clamp(0.9375rem, 1.8vw, 1.3125rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--c-ink);
    text-transform: uppercase;
    letter-spacing: 0;
    transition: color 200ms ease;
    margin-bottom: 0.3rem;
  }

  .issue-subtitle {
    font-family: var(--f-body);
    font-size: 12.5px;
    font-weight: 400;
    line-height: 1.55;
    color: var(--c-stone);
    max-width: 68ch;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* Datum + Pfeil */
  .issue-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .issue-date {
    font-family: var(--f-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--c-dust);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .issue-arrow {
    font-size: 1.125rem;
    color: var(--c-rule);
    line-height: 1;
    transition: transform 220ms cubic-bezier(0.23, 1, 0.32, 1),
                color 200ms ease;
  }

  /* Empty state */
  .list-empty {
    padding: 5rem 0;
    font-family: var(--f-body);
    font-size: 0.9375rem;
    color: var(--c-stone);
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .cta-wrap {
    margin-top: 5rem;
  }
</style>
