---
// SSR: Ausgaben kommen live von beehiiv — neue Ausgaben ohne Redeploy.
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import SignupCta from "../../components/SignupCta.astro";
import { getPost } from "../../lib/beehiiv";
import { formatDate } from "../../lib/format";

const { slug } = Astro.params;

const post = slug ? await getPost(slug) : null;

if (!post) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}
---

<Layout
  title={`${post.title} · Bits&Satoshis`}
  description={post.teaser || post.subtitle}>
  <article class="article">
    <a href="/archiv" class="article-back">← Zurück zum Archiv</a>

    <!-- Dateline wie im Hero: caps-Zeile mit Rule-Border -->
    <header class="article-header">
      <div class="article-dateline">
        <span>Bits&Satoshis</span>
        {
          post.publishedAt && (
            <time datetime={post.publishedAt.toISOString()}>
              {formatDate(post.publishedAt)}
            </time>
          )
        }
      </div>

      <h1 class="article-title">{post.title}</h1>

      {post.subtitle && <p class="article-subtitle">{post.subtitle}</p>}
    </header>

    {
      post.contentHtml ? (
        <div class="article-prose" set:html={post.contentHtml} />
      ) : (
        <div class="article-fallback">
          <p>
            Der vollständige Inhalt dieser Ausgabe ist hier noch nicht
            verfügbar.
          </p>
          {post.webUrl && post.webUrl !== "#" && (
            <a
              href={post.webUrl}
              class="article-fallback-link"
              target="_blank"
              rel="noopener">
              Auf beehiiv lesen →
            </a>
          )}
        </div>
      )
    }

    <div class="mt-16">
      {/* Spec-Default (§6.6): kein neuer Verkaufstext, identische Wiederholung */}
      <SignupCta />
    </div>
  </article>
</Layout>

<style>
  .article {
    max-width: 44rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .article-back {
    display: inline-block;
    font-family: var(--f-body);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-stone);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 160ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .article-back:hover {
    color: var(--c-orange);
  }

  /* ── Header: Dateline + Chaney-Titel ─────────────── */
  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-dateline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--c-rule);
    padding-bottom: 0.5rem;
    margin-bottom: 1.25rem;
    font-family: var(--f-body);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-dust);
  }

  .article-title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    line-height: 1.02;
    color: var(--c-ink);
    text-transform: uppercase;
    letter-spacing: 0;
    text-wrap: balance;
    margin-bottom: 0.875rem;
  }

  .article-subtitle {
    font-family: var(--f-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--c-stone);
  }

  /* ── Prose: Brand-Typografie für beehiiv-HTML ────── */
  /* set:html → :global() nötig, da der Inhalt nicht gescoped wird */

  .article-prose :global(p) {
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--c-stone);
    max-width: 68ch;
    margin: 0 0 1.25rem;
  }

  .article-prose :global(h2) {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    line-height: 1.1;
    color: var(--c-ink);
    text-transform: uppercase;
    letter-spacing: 0;
    margin: 2.5rem 0 1rem;
  }

  .article-prose :global(h3) {
    font-family: var(--f-body);
    font-size: 17px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--c-ink);
    margin: 2rem 0 0.625rem;
  }

  .article-prose :global(a) {
    color: var(--c-orange);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .article-prose :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  /* Pullquote nach DESIGN.md §10 */
  .article-prose :global(blockquote) {
    border-left: 3px solid var(--c-orange);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 1.75rem 0;
  }

  .article-prose :global(blockquote p) {
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: var(--c-ink);
    margin: 0;
  }

  .article-prose :global(strong) {
    color: var(--c-ink);
    font-weight: 700;
  }

  .article-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--c-rule);
    margin: 2.5rem 0;
  }

  .article-prose :global(ul),
  .article-prose :global(ol) {
    font-family: var(--f-body);
    font-size: 15px;
    line-height: 1.75;
    color: var(--c-stone);
    max-width: 68ch;
    margin: 0 0 1.25rem;
    padding-left: 1.375rem;
  }

  .article-prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .article-prose :global(li::marker) {
    color: var(--c-orange);
  }

  /* Bilder als Zeitungsausschnitte */
  .article-prose :global(img) {
    border: 2px solid var(--c-ink);
    max-width: 100%;
    height: auto;
    margin: 1.75rem 0;
  }

  /* Tabellen (beehiiv-Styles werden serverseitig gestrippt) */
  .article-prose :global(table) {
    border-collapse: collapse;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--c-stone);
    margin: 1.75rem 0;
    width: 100%;
  }

  .article-prose :global(th),
  .article-prose :global(td) {
    border: 1px solid var(--c-rule);
    padding: 8px 12px;
    text-align: left;
  }

  .article-prose :global(th) {
    background: var(--c-white);
    color: var(--c-ink);
    font-weight: 700;
  }

  /* ── Fallback ohne Inhalt ────────────────────────── */
  .article-fallback {
    border: var(--bd);
    background: var(--c-white);
    padding: 1.5rem;
    font-family: var(--f-body);
    font-size: 14px;
    color: var(--c-stone);
  }

  .article-fallback-link {
    display: inline-block;
    margin-top: 1rem;
    background: var(--c-orange);
    color: #fff;
    font-family: var(--f-body);
    font-size: 13px;
    font-weight: 600;
    padding: 10px 22px;
    text-decoration: none;
    transition: opacity 120ms ease;
  }

  .article-fallback-link:hover {
    opacity: 0.88;
  }
</style>
