---
// SSR: Ausgaben kommen live von beehiiv — neue Ausgaben ohne Redeploy.
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import SignupCta from "../../components/SignupCta.astro";
import IssueRow from "../../components/IssueRow.astro";
import { getPost, getPosts } from "../../lib/beehiiv";
import { formatDate, readingTimeMinutes } from "../../lib/format";

const { slug } = Astro.params;

const post = slug ? await getPost(slug) : null;

if (!post) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// Verwandte Ausgaben (§7): drei Links nach dem Formular. Schlicht die
// neuesten Ausgaben ohne die aktuelle — kein Tagging, keine Ähnlichkeitslogik.
const recent = await getPosts({ limit: 4 });
const related = recent.filter((p) => p.id !== post.id).slice(0, 3);

// Nur die neuesten Ausgaben sind hier voll lesbar; ältere werden gegatet und
// führen zum Signup. recent kommt in publish_date-desc-Ordnung wie die
// Startseite, die ersten READABLE_COUNT sind also die neuesten. Bei weniger
// als READABLE_COUNT Ausgaben sind alle lesbar.
const READABLE_COUNT = 3;
const newestIds = new Set(
  recent.slice(0, READABLE_COUNT).map((p) => p.id),
);
const isReadable = newestIds.has(post.id);

const minutes =
  isReadable && post.contentHtml ? readingTimeMinutes(post.contentHtml) : null;

// Ausgaben ändern sich nach Versand praktisch nicht — 1 h CDN-Cache reicht
// für Korrekturen, SWR hält die Auslieferung trotzdem sofort schnell.
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400",
);

// Strukturierte Daten: die Ausgabe als Artikel — Datum, Autor und Bild für
// die Suchergebnis-Darstellung.
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.teaser || post.subtitle,
  ...(post.publishedAt
    ? { datePublished: post.publishedAt.toISOString() }
    : {}),
  author: {
    "@type": "Person",
    name: "Vincent Michler",
    url: new URL("/ueber", Astro.site).href,
  },
  image: post.thumbnailUrl ?? new URL("/og-default.jpg", Astro.site).href,
  mainEntityOfPage: new URL(`/newsletter/${post.slug}`, Astro.site).href,
  inLanguage: "de",
};
---

<Layout
  title={`${post.title} · Bits&Satoshis`}
  description={post.teaser || post.subtitle}
  ogImage={post.thumbnailUrl ?? undefined}
  article={{ publishedTime: post.publishedAt }}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(articleSchema)}
  />

  {/* Gleicher Container und gleiche linke Kante wie Startseite, Archiv und
      Navbar (§4). Eine Spalte, linksbündig, 620px Satzbreite. */}
  <article class="mx-auto max-w-[1080px] px-5 pt-16 pb-16 sm:px-8">
    <div class="article-measure">
      <a href="/archiv" class="eyebrow article-back">← Alle Ausgaben</a>

      <header class="article-header">
        <p class="meta">
          {
            post.publishedAt && (
              <time datetime={post.publishedAt.toISOString()}>
                {formatDate(post.publishedAt)}
              </time>
            )
          }
          {post.publishedAt && minutes && <span aria-hidden="true"> · </span>}
          {minutes && <span>{minutes} Min. Lesezeit</span>}
        </p>

        <h1 class="h1 article-title">{post.title}</h1>

        {post.subtitle && <p class="article-subtitle">{post.subtitle}</p>}
      </header>

      <hr class="rule article-rule" />

      {
        isReadable && post.contentHtml ? (
          <div class="article-prose" set:html={post.contentHtml} />
        ) : isReadable ? (
          <div class="article-fallback">
            <p>
              Der vollständige Inhalt dieser Ausgabe ist hier noch nicht
              verfügbar.
            </p>
            {post.webUrl && post.webUrl !== "#" && (
              <a href={post.webUrl} target="_blank" rel="noopener">
                Ausgabe auf beehiiv lesen
              </a>
            )}
          </div>
        ) : (
          <div class="article-gate">
            {post.teaser && <p class="article-gate__lead">{post.teaser}</p>}
            <p>
              Nur die letzten drei Ausgaben stehen hier vollständig. Trag dich
              ein, dann kommt jede neue Ausgabe direkt in dein Postfach.
            </p>
            {post.webUrl && post.webUrl !== "#" && (
              <a href={post.webUrl} target="_blank" rel="noopener">
                Diese Ausgabe auf beehiiv lesen
              </a>
            )}
          </div>
        )
      }
    </div>
  </article>

  {/* Spec-Reihenfolge (§7): Fließtext, danach das Formular, danach drei
      Links auf verwandte Ausgaben. Kein neuer Verkaufstext (§6.6). */}
  <SignupCta />

  {
    related.length > 0 && (
      <section class="mx-auto max-w-[1080px] px-5 pb-16 sm:px-8">
        <h2 class="h2">Weiterlesen</h2>
        <hr class="rule related-rule" />
        <ul class="related-list" role="list">
          {related.map((p) => (
            <li>
              <IssueRow post={p} />
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>

<style>
  /* Lesebreite der Ausgabe: bewusst breiter als --measure (620px). Die
     Ausgaben sind lange Lesetexte, die knappe Satzbreite wirkte hier
     abgeschnitten — 720px bleibt unter der 75ch-Grenze bei 16px. */
  .article-measure {
    max-width: 720px;
    text-align: left;
  }

  /* ── Kopf ──────────────────────────────────────────
     Back-Link (Mono-Eyebrow) → Meta-Zeile → Titel → Untertitel.
     Abstände aus dem Raster: 40 / 16 / 8 (§4). */
  .article-back {
    display: inline-block;
    margin-bottom: var(--sp-4);
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .article-back:hover {
    text-decoration-color: var(--c-ink);
  }

  .article-title {
    margin-top: var(--sp-2);
    text-wrap: balance;
  }

  .article-subtitle {
    margin-top: var(--sp-1);
    font-size: 16px;
    line-height: 1.6;
    color: var(--c-stone);
    text-wrap: pretty;
  }

  .article-rule {
    margin: var(--sp-4) 0;
  }

  /* ── Prose: Brand-Typografie für beehiiv-HTML ──────
     set:html → :global() nötig, da der Inhalt nicht gescoped wird.
     Fließtext ist Ink, nie Stone (§2). Kein Orange: das Budget gehört
     dem Signup-Button (§2). */

  .article-prose :global(p) {
    font-size: 16px;
    line-height: 1.65;
    color: var(--c-ink);
    margin: 0 0 var(--sp-2);
    text-wrap: pretty;
  }

  .article-prose :global(h2) {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(1.375rem, 2.5vw, 1.5rem);
    line-height: 1.25;
    color: var(--c-ink);
    margin: var(--sp-4) 0 var(--sp-2);
  }

  .article-prose :global(h3) {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    line-height: 1.3;
    color: var(--c-ink);
    margin: var(--sp-3) 0 var(--sp-1);
  }

  /* Nur zwei Satoshi-Gewichte: 400 für Text, 500 für Hervorhebungen (§3). */
  .article-prose :global(strong),
  .article-prose :global(b) {
    font-weight: 500;
    color: var(--c-ink);
  }

  /* Einzige Link-Affordanz der Seite: Unterstrich Dust, Hover Ink (§2). */
  .article-prose :global(a) {
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .article-prose :global(a:hover) {
    text-decoration-color: var(--c-ink);
  }

  /* Fußnoten-Verweise (a > sup): Mono-Etikett statt Fließtext-Link. */
  .article-prose :global(a:has(sup)) {
    text-decoration: none;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--c-stone);
  }

  /* Pullquote als Zeitungssatz: Haarlinien statt Farbstreifen. */
  .article-prose :global(blockquote) {
    border-top: 1px solid var(--c-dust);
    border-bottom: 1px solid var(--c-dust);
    padding: var(--sp-2) 0;
    margin: var(--sp-4) 0;
  }

  .article-prose :global(blockquote p) {
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    margin: 0;
  }

  .article-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--c-dust);
    margin: var(--sp-4) 0;
  }

  .article-prose :global(ul),
  .article-prose :global(ol) {
    font-size: 16px;
    line-height: 1.65;
    color: var(--c-ink);
    margin: 0 0 var(--sp-2);
    padding-left: var(--sp-3);
  }

  .article-prose :global(li) {
    margin-bottom: var(--sp-1);
  }

  .article-prose :global(li::marker) {
    color: var(--c-stone);
  }

  /* Bilder wie aufgezogene Drucke: Haarlinie in Dust mit schmalem
     Passepartout statt hartem Ink-Rahmen — ruhiger neben dem Fließtext. */
  .article-prose :global(img) {
    border: 1px solid var(--c-dust);
    padding: var(--sp-1);
    max-width: 100%;
    height: auto;
    margin: var(--sp-3) 0 0;
  }

  /* beehiiv-Caption: das Div direkt nach dem Bild. Mono-Meta statt Absatz. */
  .article-prose :global(img + div) {
    margin-bottom: var(--sp-3);
  }

  .article-prose :global(img + div p) {
    font-family: var(--f-mono);
    font-size: 11px;
    line-height: 1.4;
    letter-spacing: 0.04em;
    color: var(--c-stone);
    margin: var(--sp-1) 0 0;
  }

  /* Bild ohne Caption: Abstand nach unten selbst tragen. */
  .article-prose :global(img:last-child) {
    margin-bottom: var(--sp-3);
  }

  /* Datentabellen (mit th): Haarlinien in Dust, kein Flächen-Hintergrund. */
  .article-prose :global(table) {
    border-collapse: collapse;
    font-size: 14px;
    line-height: 1.55;
    color: var(--c-ink);
    margin: var(--sp-3) 0;
    width: 100%;
  }

  .article-prose :global(table:has(th) th),
  .article-prose :global(table:has(th) td) {
    border: 1px solid var(--c-dust);
    padding: var(--sp-1) 12px;
    text-align: left;
  }

  .article-prose :global(th) {
    font-weight: 500;
  }

  /* Layout-Tabellen ohne th (z.B. Autoren-Signatur): randlos und kompakt.
     Das Bild darin ist Schmuck, kein Zeitungsausschnitt. width: auto schlägt
     die width-Attribute der E-Mail-Tabelle, sonst klafft eine halbe Spalte
     zwischen Bild und Text. */
  .article-prose :global(table:not(:has(th))) {
    width: auto;
  }

  .article-prose :global(table:not(:has(th)) td) {
    width: auto;
    border: none;
    padding: 0 var(--sp-2) 0 0;
    vertical-align: middle;
  }

  .article-prose :global(table:not(:has(th)) img) {
    border: none;
    padding: 0;
    max-width: 96px;
    margin: 0;
  }

  .article-prose :global(table:not(:has(th)) p) {
    margin: 0;
    font-size: 14px;
    color: var(--c-stone);
  }

  /* Kleingedrucktes: beehiiv setzt den Disclaimer in <sub>. Auf normale
     Baseline zurückholen und lesbar machen. */
  .article-prose :global(sub) {
    vertical-align: baseline;
    font-size: 12px;
    line-height: 1.5;
    color: var(--c-stone);
  }

  /* Fußnoten-Definitionen (Anker-Ziele der sup-Verweise). */
  .article-prose :global(p[id]) {
    font-size: 12px;
    line-height: 1.5;
    color: var(--c-stone);
    margin-bottom: var(--sp-1);
    scroll-margin-top: 120px;
  }

  /* Reste der E-Mail-Formatierung ohne Inhalt: keine Lücken erzeugen. */
  .article-prose :global(p:empty),
  .article-prose :global(div:empty) {
    display: none;
  }

  /* ── Fallback ohne Inhalt ────────────────────────── */
  .article-fallback p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--c-ink);
    margin: 0 0 var(--sp-2);
  }

  .article-fallback a {
    font-weight: 500;
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .article-fallback a:hover {
    text-decoration-color: var(--c-ink);
  }

  /* ── Gate: ältere Ausgaben ohne Volltext ───────────
     Kein Gatekeeping-Signal, nur ein ruhiger Hinweis vor dem Signup-CTA.
     Fließtext Ink, Link mit der Standard-Affordanz (§2). */
  .article-gate p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--c-ink);
    margin: 0 0 var(--sp-2);
  }

  /* Teaser als Meta-Vorspann: ruhiger als der Fließtext (§2). */
  .article-gate__lead {
    color: var(--c-stone);
  }

  .article-gate a {
    font-weight: 500;
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .article-gate a:hover {
    text-decoration-color: var(--c-ink);
  }

  /* ── Weiterlesen ─────────────────────────────────── */
  .related-rule {
    margin-top: var(--sp-3);
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
