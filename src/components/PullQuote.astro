---
/**
 * PullQuote — Stimmprobe auf der Startseite (§6.4a der Spec, DESIGN.md).
 *
 * Ein kuratiertes, echtes Zitat aus einer veröffentlichten Ausgabe, gerahmt
 * von zwei Haarlinien in Dust — dieselbe Pullquote-Form wie auf den
 * Ausgabenseiten (§7). Überprüfbare Stimme statt Behauptung: die Quelle ist
 * verlinkt, der Besucher kann nachlesen.
 *
 * Kein Orange, keine Karte, keine Kursivschrift als Dauerzustand — die Form
 * bleibt im Zeitungs-Register der Seite.
 */
interface Props {
  /** Das Zitat, wörtlich aus der Ausgabe. Ohne Anführungszeichen übergeben. */
  quote: string;
  /** Slug der Quell-Ausgabe (Link auf /newsletter/[slug]). */
  slug: string;
  /** Titel der Quell-Ausgabe für die Quellzeile. */
  issueTitle: string;
}

const { quote, slug, issueTitle } = Astro.props;
---

<section class="mx-auto max-w-[1080px] px-5 pb-16 sm:px-8">
  {/* Linien über den vollen Container wie jede andere Ressortgrenze (§4),
      Inhalt auf Satzbreite. Vorher lief die Rahmung selbst auf 620px und war
      damit als einzige Linie der Seite kürzer als alle übrigen — im Scroll
      las sich das als Setzfehler, nicht als eigene Form. */}
  <figure class="pull-quote">
    <blockquote class="pull-quote__text measure">{quote}</blockquote>
    <figcaption class="meta pull-quote__source">
      Aus der Ausgabe <a href={`/newsletter/${slug}`} class="pull-quote__link">{issueTitle}</a>
    </figcaption>
  </figure>
</section>

<style>
  /* Haarlinien oben und unten rahmen das Zitat — wie die Blockquotes der
     Ausgabenseiten (§7), kein Farbstreifen, keine Anführungszeichen-Grafik. */
  .pull-quote {
    margin: 0;
    padding: var(--sp-3) 0;
    border-top: 1px solid var(--c-dust);
    border-bottom: 1px solid var(--c-dust);
  }

  /* 22–28px in Satoshi 500. Vorher 19px/400: damit war die Stimmprobe der
     Marke von gewöhnlichem Fließtext (15px/400) kaum zu unterscheiden und
     leistete als Zitat nichts. Bewusst nicht die Display-Schrift — §3 lässt
     sie nur für Überschriften zu, ein mehrzeiliges Zitat ist keine. 500 ist
     das einzige zusätzlich erlaubte Satoshi-Gewicht (§3). */
  .pull-quote__text {
    margin: 0;
    font-family: var(--f-body);
    font-weight: 500;
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    line-height: 1.4;
    color: var(--c-ink);
  }

  .pull-quote__source {
    margin-top: var(--sp-2);
  }

  /* Einheitliche Link-Affordanz der Seite: Dust-Unterstrich, Hover Ink (§2). */
  .pull-quote__link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .pull-quote__link:hover {
    text-decoration-color: var(--c-ink);
  }
</style>
