---
import SignupForm from "./SignupForm.astro";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Fang an, Bitcoin wirklich zu verstehen.",
  text = "Jede Woche eine ruhige, klare Ausgabe — kostenlos in dein Postfach. Kein Hype, kein Spam, jederzeit kündbar.",
} = Astro.props;
---

<section class="border-t border-base-content/15 bg-base-200/40">
  <div class="mx-auto max-w-3xl px-6 py-16 text-center sm:py-20">
    <p class="eyebrow mb-4">Kostenlos abonnieren</p>
    <h2 class="font-display text-3xl font-semibold leading-tight sm:text-4xl">
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-md text-base-content/65">{text}</p>
    <div class="mx-auto mt-8 max-w-md text-left">
      <SignupForm variant="inline" />
    </div>
  </div>
</section>
