---
/**
 * Zweiter CTA — Sektion 6.6 der Spec (DESIGN.md).
 *
 * Identisches Formular, identisches Button-Label, identische Microcopy wie im
 * Hero. Kein neuer Verkaufstext: die Wiederholung ist der Punkt, nicht ein
 * zweiter Anlauf zu überzeugen.
 *
 * Das Formular ist dieselbe Vue-Island wie oben (SignupIsland.vue → fetch auf
 * POST /api/subscribe), nur mit eigener formId, damit die beiden Formulare auf
 * einer Seite keine doppelten Element-IDs erzeugen. Damit läuft der Signup
 * überall über denselben serverseitigen Weg zu beehiiv.
 */
import SignupIsland from "./SignupIsland.vue";

interface Props {
  /** Überschrift. Default ist der Spec-Text der Startseite (§6.6). */
  title?: string;
  /** Optionaler Zusatzsatz. Auf der Startseite bewusst leer. */
  text?: string;
  /**
   * Format-Vertrag als Mono-Zeile unter der Überschrift, z.B.
   * "Ein Thema · 4 Minuten · keine Kursprognosen · kostenlos".
   */
  format?: string;
  /**
   * Anker der Sektion. Default "newsletter" (Ziel der Navbar-Links).
   * `null`, wenn der CTA doppelt auf einer Seite steht (Wissensseiten:
   * Formular nach dem ersten Drittel) — der Anker gehört dann dem letzten.
   */
  anchorId?: string | null;
  /** Eindeutig pro Formular auf der Seite (doppelte Element-IDs vermeiden). */
  formId?: string;
}

const {
  title = "Nächste Ausgabe: Freitag.",
  text,
  format,
  anchorId = "newsletter",
  formId = "anmelden-2",
} = Astro.props;

// UTM aus der URL durchreichen — ohne sie bricht die Akquise-Statistik in
// beehiiv ab (§9). Der No-JS-Rückläufer wird hier bewusst nicht ausgewertet:
// /api/subscribe leitet auf / zurück, dort zeigt der Hero die Bestätigung.
const sp = Astro.url.searchParams;
const utm = Object.fromEntries(
  (["utm_source", "utm_medium", "utm_campaign"] as const)
    .map((key) => [key, sp.get(key)] as const)
    .filter(([, value]) => value),
) as Record<string, string>;
---

<!-- Gleicher Container wie Hero und Navbar, damit der Block mit dem Rest der
     Seite fluchtet. Linksbündig, eine Spalte, 620px Satzbreite. -->
<!-- id="newsletter": Ziel der beiden Navbar-Links. Lag vorher am Footer, der
     jetzt kein Formular mehr hat. scroll-mt-28 hält die fixe Navbar frei. -->
<section id={anchorId ?? undefined} class="mx-auto max-w-[1080px] px-5 sm:px-8">
  {/* Ressortgrenze wie überall: Haarlinie über den vollen Container,
      24px, dann der Kopf. Der Inhalt bleibt auf Satzbreite. */}
  <hr class="rule" />
  <div class="max-w-[620px] pt-6 pb-16">
    <h2 class="h2">{title}</h2>

    {format && <p class="meta mt-2">{format}</p>}

    {
      text && (
        <p class="mt-4 text-[15px] leading-[1.65] text-ink text-pretty">
          {text}
        </p>
      )
    }

    <SignupIsland client:idle utm={utm} formId={formId} />
  </div>
</section>
