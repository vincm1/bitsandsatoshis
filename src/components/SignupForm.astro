---
import { actions, isInputError } from "astro:actions";

interface Props {
  /** Darstellungsvariante. */
  variant?: "default" | "compact" | "inline";
}

const { variant = "default" } = Astro.props;

const result = Astro.getActionResult(actions.subscribe);
const inputError =
  result?.error && isInputError(result.error)
    ? result.error.fields.email?.[0]
    : undefined;
const failed = result?.error && !inputError;
const success = result && !result.error;

const fieldId = `email-${variant}`;
---

{
  variant === "inline" ? (
    <form method="POST" action={actions.subscribe} class="w-full">
      <label class="eyebrow mb-2 block" for={fieldId}>
        Kostenlos abonnieren
      </label>
      <div class="flex items-center gap-3 border-b-2 border-base-content/25 pb-2 transition-colors focus-within:border-primary">
        <input
          id={fieldId}
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="deine@email.de"
          class="w-full bg-transparent text-base outline-none placeholder:text-base-content/35"
        />
        <button
          type="submit"
          class="shrink-0 whitespace-nowrap text-sm font-bold uppercase tracking-wide text-primary"
        >
          Abonnieren →
        </button>
      </div>
    </form>
  ) : (
    <form
      method="POST"
      action={actions.subscribe}
      class:list={[
        "w-full",
        variant === "compact" ? "flex gap-2" : "flex flex-col gap-3 sm:flex-row",
      ]}
    >
      <div class="flex-1">
        <label class="sr-only" for={fieldId}>
          E-Mail-Adresse
        </label>
        <input
          id={fieldId}
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="deine@email.de"
          class="input input-bordered w-full bg-base-100"
        />
      </div>
      <button type="submit" class="btn btn-primary whitespace-nowrap rounded-full">
        Abonnieren
      </button>
    </form>
  )
}

{
  success && (
    <p class="mt-2 text-sm font-medium text-success">{result.data.message}</p>
  )
}
{inputError && <p class="mt-2 text-sm font-medium text-error">{inputError}</p>}
{
  failed && (
    <p class="mt-2 text-sm font-medium text-error">
      Da ist etwas schiefgelaufen. Bitte versuche es später erneut.
    </p>
  )
}
