---
/**
 * Footer — Sektion 6.7 der Spec (DESIGN.md).
 *
 * Navigation, Rechtliches, Disclaimer. Bewusst ohne Formular: der zweite CTA
 * (SignupCta) steht unmittelbar darüber. Ein drittes Formular wäre auch ein
 * drittes oranges Element und damit ein Verstoß gegen das Orange-Budget (§2).
 *
 * Keine Grafik, kein Wasserzeichen, kein farbiger Block: Paper ist der einzige
 * Seitenhintergrund, abgetrennt wird über eine Haarlinie in Dust (§4, §5).
 */
const year = new Date().getFullYear();

// Die Spec nennt in §13 noch /ueber-mich und /p/[slug] als Zielzustand.
// Bis diese Migration läuft, stehen hier die Routen, die es wirklich gibt.
// Labels benennen, was die Person bekommt, nicht wie die Route heißt:
// „Alle Ausgaben" statt „Archiv". Impressum/Datenschutz sind rechtlich
// feststehende Bezeichnungen und bleiben.
const links = [
  { href: "/archiv", label: "Alle Ausgaben" },
  { href: "/ueber", label: "Über mich" },
  { href: "/impressum", label: "Impressum" },
  { href: "/datenschutz", label: "Datenschutz" },
  { href: "/abmelden", label: "Abmelden" },
];

// Wissensseiten (§7): SEO-Eingänge. Der Footer ist ihr einziger fester
// Link-Ort auf der Seite — mehr interne Verlinkung braucht Google nicht,
// und die Startseite bleibt auf ihr eines Ziel fokussiert.
const wissenLinks = [
  { href: "/was-ist-bitcoin", label: "Was ist Bitcoin?" },
  { href: "/bitcoin-vs-gold", label: "Bitcoin vs. Gold" },
  { href: "/bitcoin-mythen", label: "Bitcoin-Mythen" },
  { href: "/bitcoin-kaufen", label: "Bitcoin kaufen" },
  { href: "/bitcoin-verwahren", label: "Bitcoin verwahren" },
];
---

<footer class="mt-16 border-t border-dust">
  <div class="mx-auto max-w-[1080px] px-5 sm:px-8">
    <div class="max-w-[620px] py-10">
      <a
        href="/"
        class="font-display text-[17px] leading-none text-ink hover:underline"
      >
        Bits&Satoshis
      </a>

      <nav class="mt-6 flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-[15px] leading-[1.65] text-ink underline decoration-dust underline-offset-[3px] hover:decoration-ink"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <p class="eyebrow mt-6">Wissen</p>
      <nav class="mt-2 flex flex-wrap gap-x-6 gap-y-2" aria-label="Wissen">
        {
          wissenLinks.map((link) => (
            <a
              href={link.href}
              class="text-[15px] leading-[1.65] text-ink underline decoration-dust underline-offset-[3px] hover:decoration-ink"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <p class="meta mt-10">
        Keine Anlageberatung. Was hier steht, ist meine Einschätzung, kein
        Angebot und keine Empfehlung zum Kauf oder Verkauf.
      </p>

      <p class="meta mt-2">© {year} Bits&Satoshis · Vincent Michler</p>
    </div>
  </div>
</footer>
