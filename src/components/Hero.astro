---
/**
 * Hero — Sektion 6.2 der Spec (DESIGN.md).
 *
 * Linksbündig, eine Spalte, max 620px. Ein oranges Element: der Button.
 * Das Formular ist eine Vue-Island (SignupIsland.vue): Submit client-seitig
 * als fetch an POST /api/subscribe, ohne Reload. Ohne JS greift der native
 * Form-POST an den Endpoint, der per 303 mit ?anmeldung=ok|fehler
 * hierher zurückleitet.
 */
import SignupIsland from "./SignupIsland.vue";
import Angebotskurve from "./Angebotskurve.vue";

// No-JS-Rückläufer + UTM aus der aktuellen URL (Seite läuft SSR).
const sp = Astro.url.searchParams;
const anmeldung = sp.get("anmeldung");
const success = anmeldung === "ok";
const noJsError =
  anmeldung === "fehler"
    ? "Die Anmeldung ist nicht durchgegangen. Prüf die E-Mail-Adresse und versuch es noch einmal."
    : undefined;

const utm = Object.fromEntries(
  (["utm_source", "utm_medium", "utm_campaign"] as const)
    .map((key) => [key, sp.get(key)] as const)
    .filter(([, value]) => value),
) as Record<string, string>;
---

<!-- Exakt derselbe Container wie der Header (1080px, px-5 sm:px-8), damit
     Wortmarke und H1 auf derselben linken Kante sitzen. Textblock darin
     linksbündig, nie zentriert, 620px Satzbreite (§4).

     pt-16 = 64px Abstand zwischen Haarlinie und Eyebrow. -->
<section class="mx-auto max-w-[1080px] px-5 sm:px-8">
  <!-- Ab lg zwei Spalten: Text 58 %, Grafik 42 %. Die Textspalte bleibt damit
       bei rund 590px und somit unter der 620px-Satzbreite aus §4 — die
       Ein-Spalten-Regel gilt dem Lesefluss, nicht dem Beiwerk daneben.

       Unter lg stapelt es. Die Grafik steht im DOM nach dem Formular, damit
       sie es auf 375px nicht unter die Falte drückt (§12). -->
  <div
    class="grid gap-10 pt-16 pb-16 lg:grid-cols-[minmax(0,58%)_minmax(0,42%)] lg:items-center lg:gap-10"
  >
    <div class="max-w-[620px]">
      <p class="eyebrow">Bitcoin, Geld und Politik · jeden Freitag</p>

      <!-- Der Umbruch ist gesetzt, nicht berechnet: die Pointe steht auf einer
           eigenen Zeile, sonst verliert sie ihren Absatz. -->
      <h1 class="h1 mt-2 text-balance">
        <span class="text-orange">Bitcoin</span> besitzen ist einfach.<br
        />Verstehen nicht.
      </h1>

      <!-- Subline auf 480px (§6.2), Formular auf voller Satzbreite. Ein
           schmaleres Formular sieht aufgeräumter aus, macht aber das einzige
           Element kleiner, auf das die Seite hinarbeitet (§1). -->
      <p class="mt-4 max-w-[480px] text-[15px] leading-[1.65] text-ink text-pretty">
        Ein Thema pro Woche, zu Ende gedacht. Ich sage dir, was ich davon
        halte, und wo ich mir nicht sicher bin.
      </p>

      {
        success ? (
          <p class="mt-6 text-[15px] leading-[1.65] text-ink" role="status">
            Fast fertig. Bestätige die Anmeldung in der Mail, die gerade
            rausgegangen ist.
          </p>
        ) : (
          <SignupIsland client:idle utm={utm} initialError={noJsError} />
        )
      }
    </div>

    <!-- startJahr kommt vom Server, damit SSR und Hydrierung denselben Wert
         sehen. client:visible, weil die Grafik ohne Interaktion vollständig
         als SVG dasteht — das JS wird erst gebraucht, wenn jemand zieht. -->
    <Angebotskurve client:visible kompakt startJahr={new Date().getFullYear()} />
  </div>
</section>
