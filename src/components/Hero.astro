---
import SignupForm from "./SignupForm.astro";
---

<section class="relative overflow-hidden">
  {/* dezenter Orange-Schimmer im Hintergrund */}
  <div
    class="pointer-events-none absolute -top-24 right-0 h-72 w-72 rounded-full bg-primary/10 blur-3xl"
    aria-hidden="true">
  </div>

  <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:py-28">
    <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">
      Bitcoin-Newsletter
    </p>
    <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl">
      Der ruhige Bitcoin-Newsletter für Menschen,<br class="hidden sm:block" />
      <span class="accent text-primary">die verstehen wollen</span> — nicht
      spekulieren.
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-lg text-base-content/70">
      Einmal pro Woche ein klarer Gedanke zu Bitcoin. Ohne Kursgeschrei, ohne
      Hype — nur das, was wirklich zählt.
    </p>

    <div class="mx-auto mt-10 max-w-md">
      <SignupForm />
      <p class="mt-3 text-xs text-base-content/50">
        Kostenlos. Jederzeit kündbar. Kein Spam.
      </p>
    </div>
  </div>
</section>
