---
/**
 * IssueRow — ein Eintrag der Ausgabenliste (DESIGN.md §6.3).
 *
 * Datum (Mono, Stone) · Titel (Display 17–19px, Ink) · Untertitel (Satoshi, Stone).
 * Kein Orange: das Budget aus §2 gehört den beiden Signup-Buttons.
 * Kein Hover-Hintergrund, keine Bewegung (§4, §10). Die einzige Affordanz ist
 * der unterstrichene Titel.
 */
import type { NewsletterPost } from "../lib/beehiiv";
import { formatDate } from "../lib/format";

interface Props {
  post: NewsletterPost;
}

const { post } = Astro.props;

// subtitle ist der redaktionelle Untertitel, teaser der beehiiv-Preview-Text.
// Ist keins gesetzt, entfällt die Zeile ganz.
const untertitel = post.subtitle || post.teaser;
---

<a href={`/newsletter/${post.slug}`} class="issue-row">
  {
    (post.publishedAt || post.readingTimeMinutes) && (
      <p class="meta issue-row__date">
        {post.publishedAt && (
          <time datetime={post.publishedAt.toISOString()}>
            {formatDate(post.publishedAt)}
          </time>
        )}
        {post.publishedAt && post.readingTimeMinutes && " · "}
        {post.readingTimeMinutes && `${post.readingTimeMinutes} Min.`}
      </p>
    )
  }
  <h3 class="h3 issue-row__title">{post.title}</h3>
  {untertitel && <p class="issue-row__sub">{untertitel}</p>}
</a>

<style>
  .issue-row {
    display: block;
    padding: var(--sp-3) 0;
    border-bottom: 1px solid var(--c-dust);
    text-decoration: none;
    color: inherit;
  }

  .issue-row__date {
    display: block;
  }

  /* 8px innerhalb der Textgruppe: Datum zu Titel (§4).
     Einheitliche Link-Affordanz der Seite: Unterstrich in Dust, Hover Ink. */
  .issue-row__title {
    margin-top: var(--sp-1);
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .issue-row:hover .issue-row__title {
    text-decoration-color: var(--c-ink);
  }

  .issue-row__sub {
    margin-top: var(--sp-1);
    max-width: var(--measure);
    font-size: 14px;
    line-height: 1.55;
    color: var(--c-stone);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
