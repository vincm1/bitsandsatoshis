---
/**
 * „Bevor du dich einträgst" — sechs Frage-Antwort-Paare als Churn-Bremse,
 * direkt vor dem zweiten CTA (§6.5). Hält die falschen Abonnenten ab und
 * zeigt die Stimme des Newsletters.
 *
 * Form: Zeitungs-Ledger. Ab sm steht die Frage links in einer festen
 * schmalen Spalte, die Antwort rechts; Haarlinien in Dust trennen die
 * Paare. Unter sm gestapelt. Keine Karten, keine Icons, kein Accordion.
 */
const pairs = [
  {
    q: "Soll ich jetzt kaufen?",
    a: "Das kann dir niemand seriös beantworten, ich auch nicht. Wer es trotzdem tut, verkauft dir etwas.",
  },
  {
    q: "Wo steht der Kurs Ende des Jahres?",
    a: "Das weiß niemand. Kursziele wären hier nur Dekoration, deshalb stehen sie nirgends.",
  },
  {
    q: "Welcher Coin ist der nächste Bitcoin?",
    a: "Meine Antwort ist seit Jahren dieselbe: keiner. Hier geht es um Bitcoin, sonst nichts.",
  },
  {
    q: "Verdienst du daran, wenn ich kaufe?",
    a: "Wenn ich an einer Empfehlung verdiene, steht es in derselben Zeile. Alles andere wäre es mir nicht wert.",
  },
  {
    q: "Wie oft schreibst du?",
    a: "Freitags, eine Mail, vier Minuten. Das ist der ganze Vertrag.",
  },
  {
    q: "Ist es zu spät?",
    a: "Wer so fragt, denkt an den Preis. Ich schreibe darüber, warum das die kleinere Frage ist.",
  },
] as const;
---

<section class="mx-auto max-w-[1080px] px-5 pb-16 sm:px-8">
  {/* Genau eine Haarlinie in Dust als obere Sektionsgrenze */}
  <hr class="rule" />

  <div class="measure">
    <h2 class="h2 before-signup__title">Bevor du dich einträgst</h2>

    <dl class="before-signup__list">
      {
        pairs.map((pair, index) => (
          <div
            class:list={[
              "before-signup__pair",
              index > 0 && "before-signup__pair--ruled",
            ]}
          >
            <dt class="before-signup__question">{pair.q}</dt>
            <dd class="before-signup__answer">{pair.a}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  /* Größe und Schnitt kommen aus .h2 (§3, 24–32px). Vorher hier mit 22px
     dupliziert — damit war dieser Sektionskopf kleiner als die übrigen,
     sobald .h2 angehoben wurde. Bleibt lokal nur der Abstand. */
  .before-signup__title {
    margin-top: var(--sp-3);
  }

  .before-signup__list {
    margin: var(--sp-3) 0 0;
    padding: 0;
  }

  .before-signup__pair {
    padding: var(--sp-3) 0;
  }

  /* Der Titel bringt den Abstand nach oben schon mit */
  .before-signup__pair:first-child {
    padding-top: 0;
  }

  /* Haarlinie zwischen den Paaren — läuft über beide Ledger-Spalten */
  .before-signup__pair--ruled {
    border-top: 1px solid var(--c-dust);
  }

  /* Ledger ab sm: Frage links in fester Spalte, Antwort rechts.
     Gesamtbreite bleibt innerhalb von .measure (620px, §4). */
  @media (min-width: 640px) {
    .before-signup__pair {
      display: grid;
      grid-template-columns: 180px 1fr;
      column-gap: var(--sp-4);
      align-items: start;
    }
  }

  /* 17px ist die Untergrenze für die Display-Schrift (§3) */
  .before-signup__question {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 17px;
    line-height: 1.3;
    color: var(--c-ink);
  }

  /* Fließtext ist immer Ink, nie Stone (§2) — die Antworten sind die
     Stimme der Seite, kein Kleingedrucktes. */
  .before-signup__answer {
    font-family: var(--f-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: var(--c-ink);
    margin: var(--sp-1) 0 0;
  }

  @media (min-width: 640px) {
    .before-signup__answer {
      margin-top: 0;
    }
  }
</style>
