---
/**
 * „Leserbriefe" — Leserstimmen als Zeitungs-Leserbrief-Spalte.
 * Drei Papier-Schnipsel, asymmetrisch versetzt, keine Testimonial-Grid-Optik.
 */
const letters = [
  {
    quote:
      "Ich habe drei Bitcoin-Newsletter abonniert und wieder gekündigt. Dieser hier ist geblieben. Kein Drama, einfach gute Erklärungen.",
    name: "Sabine M., München",
    variant: "light",
  },
  {
    quote:
      "Fünf Minuten am Montagmorgen, und ich verstehe mehr als nach einer Stunde YouTube.",
    name: "Jonas R., Zürich",
    variant: "dark",
  },
  {
    quote:
      "Endlich jemand, der nicht so tut, als wüsste er, wo der Kurs nächste Woche steht.",
    name: "Katrin B., Hamburg",
    variant: "strong",
  },
] as const;
---

<section class="letters-section">
  <header class="letters-header">
    <h2 class="letters-headline">LESERBRIEFE</h2>
    <div class="letters-accent" aria-hidden="true"></div>
  </header>

  <div class="letters-grid">
    {
      letters.map((letter) => (
        <figure class:list={["letter-card", `letter-${letter.variant}`]}>
          <span class="letter-mark" aria-hidden="true">"</span>
          <blockquote class="letter-quote">{letter.quote}</blockquote>
          <figcaption class="letter-attr">{letter.name}</figcaption>
        </figure>
      ))
    }
  </div>
</section>

<style>
  .letters-section {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  .letters-header {
    margin-bottom: 2rem;
  }

  .letters-headline {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    color: var(--c-ink);
    text-transform: uppercase;
    letter-spacing: 0;
    margin-bottom: 0.625rem;
  }

  /* Orange Akzentlinie — Sektions-Opener (DESIGN.md §09) */
  .letters-accent {
    width: 44px;
    height: 2px;
    background: var(--c-orange);
  }

  /* ── Grid: kontrollierte Asymmetrie ──────────────── */
  .letters-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  /* Mittlere Karte versetzt — Papier liegt nie exakt in Reihe */
  .letter-card:nth-child(2) {
    margin-top: 2rem;
  }

  @media (max-width: 820px) {
    .letters-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      max-width: 30rem;
    }
    .letter-card:nth-child(2) {
      margin-top: 0;
      /* Versatz im Einspalter: leichtes Einrücken statt Top-Offset */
      margin-left: 1.5rem;
    }
  }

  /* ── Karten-Grundform ────────────────────────────── */
  .letter-card {
    padding: 1.25rem 1.375rem 1.125rem;
    margin: 0;
  }

  /* Variante 1: weiß, feine Border */
  .letter-light {
    background: var(--c-white);
    border: var(--bd);
  }

  /* Variante 2: Ink-Dark-Card — Echo der Hero-Quote, einzige Rotation */
  .letter-dark {
    background: var(--c-ink);
    transform: rotate(1.5deg);
    transition: transform 200ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .letter-dark:hover {
    transform: rotate(0deg);
  }

  /* Variante 3: weiß, harte Clipping-Border */
  .letter-strong {
    background: var(--c-white);
    border: var(--bd-strong);
  }

  /* ── Innenleben ──────────────────────────────────── */
  .letter-mark {
    display: block;
    font-family: var(--f-display);
    font-size: 2rem;
    line-height: 0.75;
    color: var(--c-ink);
    margin-bottom: 0.375rem;
  }

  .letter-dark .letter-mark {
    color: var(--c-orange);
  }

  .letter-quote {
    font-family: var(--f-body);
    font-style: italic;
    font-size: 13.5px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--c-stone);
    margin: 0 0 0.75rem;
  }

  .letter-dark .letter-quote {
    color: rgba(244, 237, 224, 0.85);
  }

  .letter-attr {
    font-family: var(--f-body);
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-dust);
  }

  .letter-dark .letter-attr {
    color: rgba(244, 237, 224, 0.55);
  }

  /* ── Reduced motion ──────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .letter-dark {
      transition: none;
    }
  }
</style>
