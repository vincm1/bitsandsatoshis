---
/**
 * Autoren-Sektion (§6.4) — Portrait links, Text rechts, auf Mobil untereinander.
 * Einsatz: Homepage (nach Ausgaben-Liste) + /ueber (oben, ohne Selbst-Link).
 * Keine Karte, keine Rotation, kein Orange. Ressortgrenze wie überall:
 * Haarlinie in Dust, 24px, dann der Inhalt.
 */
interface Props {
  /** Link „Mehr über mich" ausblenden (auf /ueber selbst). */
  showLink?: boolean;
}

const { showLink = true } = Astro.props;
---

<section class="mx-auto max-w-[1080px] px-5 pb-16 sm:px-8">
  <hr class="rule" />

  <div class="author mt-6">
    {
      showLink ? (
        <a href="/ueber" class="author__photo-frame" aria-label="Mehr über Vincent">
          <img
            src="/author.png"
            alt="Vincent, Autor von Bits&Satoshis"
            class="author__photo"
            width="112"
            height="112"
            loading="lazy"
          />
        </a>
      ) : (
        <span class="author__photo-frame">
          <img
            src="/author.png"
            alt="Vincent, Autor von Bits&Satoshis"
            class="author__photo"
            width="112"
            height="112"
            loading="lazy"
          />
        </span>
      )
    }

    <div class="author__text measure">
      <h2 class="h2">Ich bin Vincent.</h2>
      <p class="author__body">
        Bits&amp;Satoshis gibt es, weil ich Bitcoin verstehen wollte und fast
        alles auf Deutsch entweder etwas verkaufen oder ein Video sein wollte.
      </p>
      <p class="author__body">
        Ich rechne nach, statt zu raten. Ich lese mich in ein Thema ein, prüfe
        die Zahlen, wo es welche gibt, und schreibe auf, was dabei rauskommt.
        Auch wenn es gegen das läuft, was ich vorher gedacht habe.
      </p>
      {
        showLink && (
          <a href="/ueber" class="author__link">
            Mehr über mich
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .author {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
  }

  @media (max-width: 640px) {
    .author {
      flex-direction: column;
      gap: var(--sp-3);
    }
  }

  .author__photo-frame {
    flex-shrink: 0;
    display: block;
  }

  .author__photo {
    width: 112px;
    height: 112px;
    display: block;
    object-fit: cover;
    /* Kreis ist hier erlaubt: Portrait, kein UI-Element (§6.4) */
    border-radius: 50%;
  }

  .author__body {
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--c-ink);
  }

  .h2 + .author__body,
  .author__body + .author__body {
    margin-top: var(--sp-2);
  }

  .author__link {
    display: inline-block;
    margin-top: var(--sp-2);
    font-family: var(--f-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--c-ink);
    text-decoration: underline;
    text-decoration-color: var(--c-dust);
    text-underline-offset: 3px;
  }

  .author__link:hover {
    text-decoration-color: var(--c-ink);
  }
</style>
