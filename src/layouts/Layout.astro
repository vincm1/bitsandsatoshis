---
import "../styles/global.css";

// Schriften laufen über die Astro-Fonts-API (astro.config.mjs) — self-hosted,
// kein Drittanbieter-Request im Browser des Besuchers.
import { Font } from "astro:assets";

import Analytics from '@vercel/analytics/astro'
import Navbar from "../components/Navbar.vue";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** Pfad zu einem seiten-spezifischen OG-Bild (Default: /og-default.jpg). */
  ogImage?: string;
  /** Gesetzt auf Ausgabenseiten: schaltet og:type=article + Artikel-Tags. */
  article?: {
    publishedTime: Date | null;
  };
  /** Funktionale Seiten (z.B. /willkommen) aus dem Google-Index halten. */
  noindex?: boolean;
}

const {
  title = "Bits&Satoshis · Der ruhige Bitcoin-Newsletter",
  description = "Der ruhige Bitcoin-Newsletter für Menschen, die verstehen wollen, nicht spekulieren.",
  ogImage = "/og-default.jpg",
  article,
  noindex = false,
} = Astro.props;

const AUTHOR = "Vincent Michler";

// Absolute URLs für Canonical und og:* — Basis ist `site` aus astro.config.mjs.
// `new URL()` lässt bereits absolute ogImage-Werte (beehiiv-Thumbnails) intakt.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
// Maße sind nur für das eigene Default-Bild bekannt.
const isDefaultOgImage = ogImage === "/og-default.jpg";

// Strukturierte Daten: WebSite auf jeder Seite — Google versteht darüber
// Name, Sprache und Herausgeber der Site.
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Bits&Satoshis",
  url: Astro.site?.href,
  description:
    "Der ruhige Bitcoin-Newsletter für Menschen, die verstehen wollen, nicht spekulieren.",
  inLanguage: "de",
  publisher: {
    "@type": "Person",
    name: AUTHOR,
    url: new URL("/ueber", Astro.site).href,
  },
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" href="/favicon.ico?v=3" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Bits&Satoshis"
      href={new URL("/rss.xml", Astro.site)}
    />
    <meta property="og:site_name" content="Bits&Satoshis" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={article ? "article" : "website"} />
    {
      article?.publishedTime && (
        <meta
          property="article:published_time"
          content={article.publishedTime.toISOString()}
        />
      )
    }
    {article && <meta property="article:author" content={AUTHOR} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    {isDefaultOgImage && <meta property="og:image:width" content="1200" />}
    {isDefaultOgImage && <meta property="og:image:height" content="630" />}
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(websiteSchema)}
    />
    <!-- Archivo (Überschriften) + Satoshi (Fließtext) werden von der
         eigenen Domain ausgeliefert und vorgeladen. Mono trägt nur Meta-Text
         und braucht kein preload. -->
    <Font cssVariable="--font-brand-display" preload />
    <Font cssVariable="--font-brand-body" preload />
    <Font cssVariable="--font-brand-mono" />
    <!-- Cookielose Reichweitenmessung (Datenschutzerklärung §4). Lädt im
         Prod-Build von der eigenen Domain (/_vercel/insights). -->
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col bg-base-100 text-base-content antialiased">
    <!-- Ohne client-Direktive: der Header ist statisches Markup (§10 verbietet
         Scroll-Animationen), es wird also kein Vue an den Browser geliefert.
         Er steht außerdem im Fluss statt fixed — den Abstand darunter setzt
         der Hero selbst mit 64px. -->
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
